@model IEnumerable<Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="page-title-row">
    <div>
        <p class="eyebrow">Menu organization</p>
        <h1>Categories</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Category</a>
</div>

<table class="table table-polished">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Products</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.Description</td>
                <td>@category.Products.Count</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@category.CategoryId">Details</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@category.CategoryId">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@category.CategoryId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
