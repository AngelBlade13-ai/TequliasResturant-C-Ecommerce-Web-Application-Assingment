@model ProductFormViewModel

<div class="mb-3">
    <label asp-for="Product.Name" class="form-label"></label>
    <input asp-for="Product.Name" class="form-control" />
    <span asp-validation-for="Product.Name" class="text-danger"></span>
</div>
<div class="mb-3">
    <label asp-for="Product.Description" class="form-label"></label>
    <textarea asp-for="Product.Description" class="form-control"></textarea>
    <span asp-validation-for="Product.Description" class="text-danger"></span>
</div>
<div class="row">
    <div class="col-md-4 mb-3">
        <label asp-for="Product.Price" class="form-label"></label>
        <input asp-for="Product.Price" class="form-control" />
        <span asp-validation-for="Product.Price" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="Product.Stock" class="form-label"></label>
        <input asp-for="Product.Stock" class="form-control" />
        <span asp-validation-for="Product.Stock" class="text-danger"></span>
    </div>
    <div class="col-md-4 mb-3">
        <label asp-for="Product.CategoryId" class="form-label">Category</label>
        <select asp-for="Product.CategoryId" asp-items="Model.Categories" class="form-select"></select>
        <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
    </div>
</div>
<div class="mb-3">
    <label asp-for="Product.ImageUrl" class="form-label">Image URL</label>
    <input asp-for="Product.ImageUrl" class="form-control" />
    <span asp-validation-for="Product.ImageUrl" class="text-danger"></span>
</div>
<fieldset class="mb-3">
    <legend class="h5">Ingredients</legend>
    <div class="row">
        @foreach (var ingredient in Model.Ingredients)
        {
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="SelectedIngredientIds" value="@ingredient.Value" checked="@ingredient.Selected" id="ingredient-@ingredient.Value" />
                    <label class="form-check-label" for="ingredient-@ingredient.Value">@ingredient.Text</label>
                </div>
            </div>
        }
    </div>
</fieldset>
