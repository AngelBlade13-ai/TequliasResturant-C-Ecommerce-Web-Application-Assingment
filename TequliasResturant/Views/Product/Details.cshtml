@model Product

@{
    ViewData["Title"] = Model.Name;
}

<h1>@Model.Name</h1>

<dl class="row">
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Category?.Name</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price.ToString("C")</dd>
    <dt class="col-sm-2">Stock</dt>
    <dd class="col-sm-10">@Model.Stock</dd>
    <dt class="col-sm-2">Ingredients</dt>
    <dd class="col-sm-10">@string.Join(", ", Model.ProductIngredients.Select(item => item.Ingredient?.Name))</dd>
</dl>

<a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ProductId">Edit</a>
<a class="btn btn-outline-secondary" asp-action="Index">Back to Products</a>
