@model ProductFormViewModel

@{
    ViewData["Title"] = "Edit Product";
}

<h1>Edit Product</h1>

<form asp-action="Edit" asp-route-id="@Model.Product.ProductId" method="post" class="col-lg-7">
    <input asp-for="Product.ProductId" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <partial name="_ProductFormFields" model="Model" />
    <button class="btn btn-primary" type="submit">Save Changes</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
