@model Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1>Delete Product</h1>
<p class="text-danger">Are you sure you want to delete this product?</p>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Category?.Name</dd>
    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price.ToString("C")</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.ProductId" method="post">
    <button class="btn btn-danger" type="submit">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>
