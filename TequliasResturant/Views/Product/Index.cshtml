@model IEnumerable<Product>

@{
    ViewData["Title"] = "Products";
}

<div class="page-title-row">
    <div>
        <p class="eyebrow">Menu</p>
        <h1>Products</h1>
        <p class="text-muted mb-0">Manage menu items or browse what customers can order.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Product</a>
</div>

<div class="row g-4">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card menu-card h-100">
                <img class="menu-card-img" src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/tequilas-hero.png") : product.ImageUrl)" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between gap-3">
                        <h2 class="h5">@product.Name</h2>
                        <span class="price-pill">@product.Price.ToString("C")</span>
                    </div>
                    <p class="menu-desc">@product.Description</p>
                    <p class="mb-1"><span class="meta-label">Category</span> @product.Category?.Name</p>
                    <p class="mb-2"><span class="meta-label">Stock</span> @product.Stock</p>
                    <p class="ingredient-list"><span class="meta-label">Ingredients</span> @string.Join(", ", product.ProductIngredients.Select(item => item.Ingredient?.Name))</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@product.ProductId">Details</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@product.ProductId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.ProductId">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
