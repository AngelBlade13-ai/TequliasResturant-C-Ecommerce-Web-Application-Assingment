@model IEnumerable<Product>

@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Products</h1>
    <a class="btn btn-primary" asp-action="Create">Add Product</a>
</div>

<div class="row g-3">
    @foreach (var product in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">@product.Name</h2>
                    <p>@product.Description</p>
                    <p class="mb-1"><strong>Category:</strong> @product.Category?.Name</p>
                    <p class="mb-1"><strong>Stock:</strong> @product.Stock</p>
                    <p class="mb-2"><strong>Ingredients:</strong> @string.Join(", ", product.ProductIngredients.Select(item => item.Ingredient?.Name))</p>
                    <p class="fw-bold mt-auto">@product.Price.ToString("C")</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@product.ProductId">Details</a>
                        <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@product.ProductId">Edit</a>
                        <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@product.ProductId">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
