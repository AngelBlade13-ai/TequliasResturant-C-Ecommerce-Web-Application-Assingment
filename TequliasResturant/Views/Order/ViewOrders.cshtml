@model IEnumerable<Order>

@{
    ViewData["Title"] = "My Orders";
}

<h1>My Orders</h1>

<table class="table">
    <thead>
        <tr>
            <th>Order ID</th>
            <th>Date</th>
            <th>Total</th>
            <th>Items</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderId</td>
                <td>@order.OrderDate.ToShortDateString()</td>
                <td>@order.TotalAmount.ToString("C")</td>
                <td>
                    @foreach (var item in order.OrderItems)
                    {
                        <div>@item.Product?.Name x @item.Quantity (@item.Price.ToString("C"))</div>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
