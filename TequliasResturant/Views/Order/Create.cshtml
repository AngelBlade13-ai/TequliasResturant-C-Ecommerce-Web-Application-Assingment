@model OrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h1>Create Order</h1>

<div class="row g-3">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h2 class="h5">@product.Name</h2>
                    <p>@product.Description</p>
                    <p class="fw-bold mt-auto">@product.Price.ToString("C")</p>
                    <form asp-action="AddItem" method="post" class="d-flex gap-2">
                        <input type="hidden" name="prodId" value="@product.ProductId" />
                        <input class="form-control" type="number" name="prodQty" value="1" min="1" />
                        <button class="btn btn-success" type="submit">Add</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
