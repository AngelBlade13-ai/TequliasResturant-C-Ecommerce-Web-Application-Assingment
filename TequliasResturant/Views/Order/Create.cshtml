@model OrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<div class="page-title-row">
    <div>
        <p class="eyebrow">Online ordering</p>
        <h1>Create Order</h1>
        <p class="text-muted mb-0">Pick a quantity, add items to your cart, and check out when ready.</p>
    </div>
    <a class="btn btn-outline-primary" asp-action="Cart">View Cart</a>
</div>

@if (TempData["CartMessage"] is not null)
{
    <div class="alert alert-warning">@TempData["CartMessage"]</div>
}

<div class="row g-4">
    @foreach (var product in Model.Products)
    {
        <div class="col-md-4">
            <div class="card menu-card h-100">
                <img class="menu-card-img" src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/tequilas-hero.png") : product.ImageUrl)" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between gap-3">
                        <h2 class="h5">@product.Name</h2>
                        <span class="price-pill">@product.Price.ToString("C")</span>
                    </div>
                    <p class="menu-desc">@product.Description</p>
                    <p class="mb-3"><span class="meta-label">Available</span> @product.Stock</p>
                    <form asp-action="AddItem" method="post" class="d-flex gap-2">
                        <input type="hidden" name="prodId" value="@product.ProductId" />
                        <input class="form-control" type="number" name="prodQty" value="1" min="1" max="@product.Stock" />
                        <button class="btn btn-success" type="submit" disabled="@(product.Stock <= 0)">Add</button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>
