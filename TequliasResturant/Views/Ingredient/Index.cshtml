@model IEnumerable<Ingredient>

@{
    ViewData["Title"] = "Ingredients";
}

<div class="page-title-row">
    <div>
        <p class="eyebrow">Kitchen inventory</p>
        <h1>Ingredients</h1>
    </div>
    <a class="btn btn-primary" asp-action="Create">Add Ingredient</a>
</div>

<table class="table table-polished">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var ingredient in Model)
        {
            <tr>
                <td>@ingredient.Name</td>
                <td>@ingredient.Description</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@ingredient.IngredientId">Details</a>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@ingredient.IngredientId">Edit</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@ingredient.IngredientId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
