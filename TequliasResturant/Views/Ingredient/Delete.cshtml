@model Ingredient

@{
    ViewData["Title"] = "Delete Ingredient";
}

<h1>Delete Ingredient</h1>
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<p class="text-danger">Are you sure you want to delete this ingredient?</p>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Products</dt>
    <dd class="col-sm-10">@Model.ProductIngredients.Count</dd>
</dl>

<form asp-action="Delete" asp-route-id="@Model.IngredientId" method="post">
    <button class="btn btn-danger" type="submit">Delete</button>
    <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
</form>
