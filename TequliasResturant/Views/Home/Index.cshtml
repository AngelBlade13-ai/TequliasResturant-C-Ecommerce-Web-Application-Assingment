@{
    ViewData["Title"] = "Home";
}

<section class="hero-panel">
    <div class="hero-copy">
        <p class="eyebrow">Tooele's casual taco stop</p>
        <h1>Fresh Mexican favorites, ready when you are.</h1>
        <p class="lead">Browse the menu, build a cart, and place a simple online order for tacos, drinks, and restaurant favorites.</p>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary btn-lg" asp-controller="Order" asp-action="Create">Start an Order</a>
            <a class="btn btn-outline-light btn-lg" asp-controller="Product" asp-action="Index">View Menu</a>
        </div>
    </div>
</section>

<section class="feature-strip">
    <div>
        <strong>Fresh Ingredients</strong>
        <span>Menu items connect directly to ingredients.</span>
    </div>
    <div>
        <strong>Simple Cart</strong>
        <span>Session-based cart keeps your order together.</span>
    </div>
    <div>
        <strong>Order History</strong>
        <span>Registered users can review past orders.</span>
    </div>
</section>

<section class="section-heading">
    <p class="eyebrow">Built with ASP.NET Core MVC</p>
    <h2>Restaurant ordering demo</h2>
    <p>This project shows authentication, Entity Framework relationships, CRUD pages, product ingredients, cart session data, and checkout.</p>
</section>
