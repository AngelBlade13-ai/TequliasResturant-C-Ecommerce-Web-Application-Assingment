@{
    ViewData["Title"] = "Home";
}

<section class="py-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <h1 class="display-5 fw-semibold">Tequilas Restaurant e-commerce skeleton</h1>
            <p class="lead">A follow-along starter for the ASP.NET Core MVC tutorial: Identity login, EF Core models, repository pattern, menu catalog, cart, and orders.</p>
            <div class="d-flex gap-2">
                <a class="btn btn-primary" asp-controller="Product" asp-action="Index">View Products</a>
                <a class="btn btn-outline-secondary" asp-controller="Order" asp-action="Create">Start Order</a>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="border rounded p-4 bg-light">
                <h2 class="h5">Follow-along checklist</h2>
                <ul class="mb-0">
                    <li>Run migrations for the restaurant tables.</li>
                    <li>Replace shortcut forms with polished CRUD pages.</li>
                    <li>Connect products to ingredients.</li>
                    <li>Improve order history display.</li>
                    <li>Add screenshots for the assignment submission.</li>
                </ul>
            </div>
        </div>
    </div>
</section>
